# Ollama (defaults work if Ollama runs on localhost:11434)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.3:70b

# Serper (Google search). Optional — sans clé, l'étape "concurrents" tourne mais avec search_quality="poor".
# Récupère une clé gratuite (2500 requêtes) sur https://serper.dev
SERPER_API_KEY=
